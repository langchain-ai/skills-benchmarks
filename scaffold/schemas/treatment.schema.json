{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "treatment.schema.json",
  "title": "Treatment",
  "description": "Schema for experiment treatment definitions. Both Python and JavaScript implementations must conform to this interface.",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier for the treatment"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of what this treatment tests"
    },
    "skills": {
      "type": "object",
      "description": "Map of skill name to skill configuration",
      "additionalProperties": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "Skill content (markdown)"
          },
          "scripts_dir": {
            "type": "string",
            "description": "Path to scripts directory (optional)"
          }
        }
      }
    },
    "claude_md": {
      "type": "string",
      "description": "Content for CLAUDE.md file (optional)"
    },
    "noise_tasks": {
      "type": "array",
      "description": "List of noise tasks to insert between main tasks",
      "items": {
        "type": "object",
        "required": ["prompt", "deliverables"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "The task prompt"
          },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Expected files this task should create"
          }
        }
      }
    },
    "validators": {
      "type": "array",
      "description": "List of validators to run after the experiment",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Validator class name (e.g., 'SkillInvokedValidator', 'ScriptValidator')"
          },
          "args": {
            "type": "object",
            "description": "Arguments to pass to the validator constructor",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
