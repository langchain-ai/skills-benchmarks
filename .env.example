# =============================================================================
# Required
# =============================================================================

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=skills

# OpenAI (for tests using OpenAI models and LLM-as-judge evaluation)
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Optional
# =============================================================================

# Claude Code version to install in Docker. Each pinned version gets its own
# cached image. If unset, uses a separate unversioned cache slot — this won't
# pick up pinned versions you've built before. Set explicitly for reproducibility.
BENCH_CC_VERSION=2.1.63

# Claude Code model (uses Claude Code's default if unset)
BENCH_CC_MODEL=claude-sonnet-4-5-20250929

# LLM-as-judge model for validation checks (default: openai:gpt-4o-mini)
BENCH_EVAL_MODEL=openai:gpt-4o-mini

# Docker data transport filenames (defaults should be fine for most users)
BENCH_TEST_CONTEXT=_test_context.json
BENCH_TEST_RESULTS=_test_results.json

# LangSmith workspace ID (only needed for multi-workspace setups)
# LANGSMITH_WORKSPACE_ID=

# LangSmith test suite name (default: skills-benchmark)
# LANGSMITH_TEST_SUITE=skills-benchmark

# Tavily API key (required for lc-deps-tavily task)
TAVILY_API_KEY=tvly-...

# =============================================================================
# Claude Code LangSmith tracing (optional)
# =============================================================================
# Set TRACE_TO_LANGSMITH=true to send Claude Code traces to LangSmith.
# CC_LANGSMITH_API_KEY is the API key used by the stop hook inside Docker.
# CC_LANGSMITH_PROJECT controls which project CC traces go to. During
# benchmark runs this is automatically set to the experiment's temp project
# so that CC traces nest under the experiment row — without it, traces
# would go to the default project and not appear in experiments.
TRACE_TO_LANGSMITH=true
CC_LANGSMITH_API_KEY=lsv2_...
CC_LANGSMITH_PROJECT=claude-code
